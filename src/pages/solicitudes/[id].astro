---
import UserLayout from "../../layouts/UserLayout.astro";

export const prerender = false;
---

<UserLayout title="Detalle Solicitud">

  <div
    id="detalleContainer"
    class="bg-white rounded-3xl shadow-md p-8"
  >

    <h1 class="text-3xl font-bold">
      Cargando...
    </h1>

  </div>

<script>

  const token =
    localStorage.getItem("token");

  async function cargarDetalle() {

    try {

      const id =
        window.location.pathname
          .split("/")
          .pop();

      const response =
        await fetch(
          `http://localhost:3000/api/solicitudes/${id}`,
          {
            headers: {
              Authorization:
                `Bearer ${token}`
            }
          }
        );

      const solicitud =
        await response.json();

      const container =
        document.getElementById(
          "detalleContainer"
        );

      container.innerHTML = `
        <h1 class="text-4xl font-bold text-slate-800 mb-6">
          ${solicitud.modelo}
        </h1>

        <div class="space-y-4">

          <div>
            <strong>Estado:</strong>
            ${solicitud.estado}
          </div>

          <div>
            <strong>Motivo:</strong>
            ${solicitud.motivo}
          </div>

          <div>
            <strong>Fecha:</strong>
            ${new Date(
              solicitud.fecha_solicitud
            ).toLocaleDateString()}
          </div>

          ${
            solicitud.observacion
            ? `
                <div>
                <strong>
                    Observación:
                </strong>
                ${solicitud.observacion}
                </div>
            `
            : ""
            }

          <a
            href="/solicitudes"
            class="inline-block mt-4 bg-blue-600 text-white px-6 py-3 rounded-xl hover:bg-blue-700 transition"
          >
            Volver
          </a>

        </div>
      `;

    } catch (error) {

      console.error(error);

    }

  }

  cargarDetalle();

</script>

</UserLayout>