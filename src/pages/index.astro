---
import "../styles/global.css";
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sistema de Certificados</title>
  </head>

  <body class="bg-slate-50 text-slate-800">

    <!-- NAVBAR -->
    <header class="bg-white shadow-md">
      <div class="max-w-7xl mx-auto px-8 py-5 flex justify-between items-center">
        <h1 class="text-2xl font-bold text-blue-600">
          CERTIFICADOS
        </h1>

        <div class="flex gap-4">
          <a
            href="/login"
            class="px-5 py-2 rounded-xl border border-blue-600 text-blue-600 hover:bg-blue-50"
          >
            Iniciar sesión
          </a>

          <a
            href="/register"
            class="px-5 py-2 rounded-xl bg-blue-600 text-white hover:bg-blue-700"
          >
            Registrarse
          </a>
        </div>
      </div>
    </header>

    <!-- HERO -->
    <section class="max-w-7xl mx-auto px-8 py-24 grid md:grid-cols-2 gap-12 items-center">

      <div>
        <h2 class="text-5xl font-bold leading-tight">
          Sistema Inteligente de Gestión de Certificados Académicos
        </h2>

        <p class="text-gray-600 text-lg mt-6">
          Gestiona solicitudes, genera certificados y administra procesos académicos
          de forma rápida, segura y eficiente.
        </p>

        <div class="mt-8 flex gap-4">
          <a
            href="/login"
            class="bg-blue-600 text-white px-6 py-3 rounded-xl hover:bg-blue-700"
          >
            Comenzar
          </a>

          <a
            href="#features"
            class="border border-slate-300 px-6 py-3 rounded-xl hover:bg-slate-100"
          >
            Ver características
          </a>
        </div>
      </div>

      <div class="bg-white shadow-xl rounded-3xl p-10">
        <div class="grid grid-cols-2 gap-6">

          <div class="bg-slate-100 p-6 rounded-2xl">
            <h3 class="font-semibold text-lg">Solicitudes</h3>
            <p class="text-3xl font-bold mt-3">128</p>
          </div>

          <div class="bg-slate-100 p-6 rounded-2xl">
            <h3 class="font-semibold text-lg">Certificados</h3>
            <p class="text-3xl font-bold mt-3">54</p>
          </div>

          <div class="bg-slate-100 p-6 rounded-2xl">
            <h3 class="font-semibold text-lg">Usuarios</h3>
            <p class="text-3xl font-bold mt-3">240</p>
          </div>

          <div class="bg-slate-100 p-6 rounded-2xl">
            <h3 class="font-semibold text-lg">Activos</h3>
            <p class="text-3xl font-bold mt-3">98%</p>
          </div>

        </div>
      </div>

    </section>

    <!-- FEATURES -->
    <section id="features" class="bg-white py-20">
      <div class="max-w-7xl mx-auto px-8">

        <h2 class="text-4xl font-bold text-center mb-14">
          Funcionalidades principales
        </h2>

        <div class="grid md:grid-cols-3 gap-8">

          <div class="bg-slate-50 p-8 rounded-2xl shadow-sm">
            <h3 class="text-xl font-bold mb-4">
              Gestión de certificados
            </h3>

            <p class="text-gray-600">
              Solicitud y visualización de certificados académicos digitales.
            </p>
          </div>

          <div class="bg-slate-50 p-8 rounded-2xl shadow-sm">
            <h3 class="text-xl font-bold mb-4">
              Administración segura
            </h3>

            <p class="text-gray-600">
              Control de usuarios, roles y procesos administrativos.
            </p>
          </div>

          <div class="bg-slate-50 p-8 rounded-2xl shadow-sm">
            <h3 class="text-xl font-bold mb-4">
              Seguimiento en tiempo real
            </h3>

            <p class="text-gray-600">
              Consulta el estado de tus solicitudes en cualquier momento.
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="bg-slate-900 text-white py-10 mt-10">
      <div class="max-w-7xl mx-auto px-8 text-center">
        <p>
          Sistema de Certificados Académicos © 2026
        </p>
      </div>
    </footer>

  </body>
</html>