---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Soporte">

  <div class="mb-8">
    <h1 class="text-3xl font-bold text-slate-800">
      Mensajes de Soporte
    </h1>

    <p class="text-gray-500 mt-2">
      Gestiona las consultas enviadas por los usuarios.
    </p>
  </div>

  <!-- Contenedor con scroll -->
  <div
    id="mensajesContainer"
    class="h-[calc(100vh-180px)] overflow-y-auto pr-2 space-y-6"
  >
    <div class="bg-white rounded-3xl shadow-md p-6">
      Cargando mensajes...
    </div>
  </div>

<script>

const token = localStorage.getItem("token");

async function responderMensaje(id){

    const respuesta = prompt("Ingrese la respuesta:");

    if(!respuesta) return;

    try{

        const response = await fetch(
            `http://localhost:3000/api/soporte/${id}/responder`,
            {
                method:"PUT",
                headers:{
                    "Content-Type":"application/json",
                    Authorization:`Bearer ${token}`
                },
                body:JSON.stringify({respuesta})
            }
        );

        const data = await response.json();

        alert(data.message);

        cargarMensajes();

    }catch(error){

        console.error(error);

    }

}

async function cargarMensajes(){

    try{

        const response = await fetch(
            "http://localhost:3000/api/soporte",
            {
                headers:{
                    Authorization:`Bearer ${token}`
                }
            }
        );

        const mensajes = await response.json();

        const container = document.getElementById("mensajesContainer");

        container.innerHTML = "";

        if(mensajes.length===0){

            container.innerHTML=`
                <div class="bg-white rounded-3xl shadow-md p-6">
                    No existen mensajes.
                </div>
            `;

            return;

        }

        mensajes.forEach(mensaje=>{

            container.innerHTML += `

            <div class="bg-white rounded-3xl shadow-md border p-6">

                <h2 class="text-2xl font-bold mb-4">
                    ${mensaje.asunto}
                </h2>

                <p class="mb-4">
                    <strong>Usuario:</strong>
                    ${mensaje.email}
                </p>

                <div class="mb-5">

                    <strong>Mensaje:</strong>

                    <div class="mt-2 h-28 overflow-y-auto border rounded-xl bg-gray-50 p-4">

                        <p class="whitespace-pre-wrap break-words">
                            ${mensaje.mensaje}
                        </p>

                    </div>

                </div>

                <p class="mb-5">
                    <strong>Estado:</strong>

                    <span class="${
                        mensaje.estado==="pendiente"
                        ? "text-orange-600 font-semibold"
                        : "text-green-600 font-semibold"
                    }">

                        ${mensaje.estado}

                    </span>

                </p>

                ${
                    mensaje.estado==="pendiente"

                    ?

                    `
                    <button
                        onclick="responderMensaje(${mensaje.id})"
                        class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded-xl transition"
                    >
                        Responder
                    </button>
                    `

                    :

                    `
                    <div class="bg-green-50 border border-green-200 rounded-xl p-4">

                        <strong>
                            Respuesta:
                        </strong>

                        <div class="mt-2 h-28 overflow-y-auto border rounded-xl bg-white p-4">

                            <p class="whitespace-pre-wrap break-words">
                                ${mensaje.respuesta}
                            </p>

                        </div>

                    </div>
                    `

                }

            </div>

            `;

        });

    }catch(error){

        console.error(error);

    }

}

window.responderMensaje = responderMensaje;

cargarMensajes();

</script>

</AdminLayout>