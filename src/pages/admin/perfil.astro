---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Mi Perfil">

  <div class="bg-white rounded-3xl shadow-md p-8">

    <div class="mb-8">
      <h1 class="text-3xl font-bold text-slate-800">
        Perfil Administrador
      </h1>

      <p class="text-gray-500 mt-2">
        Información de la cuenta administrativa.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">

        <div class="bg-slate-50 p-6 rounded-2xl">
            <h3 class="font-semibold text-gray-500 mb-2">
            Correo electrónico
            </h3>

            <input
            id="email"
            type="email"
            disabled
            class="w-full border rounded-xl px-4 py-3 bg-gray-100"
            placeholder="Correo electrónico"
            />
        </div>

        <div class="bg-slate-50 p-6 rounded-2xl">
            <h3 class="font-semibold text-gray-500 mb-2">
            Rol
            </h3>

            <p id="rol" class="text-xl font-bold">
            Cargando...
            </p>
        </div>

        <div class="bg-slate-50 p-6 rounded-2xl">
            <h3 class="font-semibold text-gray-500 mb-2">
            Estado
            </h3>

            <p id="estado" class="text-xl font-bold">
            Cargando...
            </p>
        </div>

        <div class="bg-slate-50 p-6 rounded-2xl">
            <h3 class="font-semibold text-gray-500 mb-2">
            Fecha de registro
            </h3>

            <p id="fecha" class="text-xl font-bold">
            Cargando...
            </p>
        </div>

        </div>

        <div class="mt-8 flex gap-4">

        <button
            id="editarBtn"
            class="bg-yellow-500 text-white px-6 py-3 rounded-xl hover:bg-yellow-600 transition"
        >
            Editar
        </button>

        <button
            id="guardarBtn"
            class="bg-blue-600 text-white px-6 py-3 rounded-xl hover:bg-blue-700 transition hidden"
        >
            Guardar cambios
        </button>

        <button
            id="cancelarBtn"
            class="bg-gray-500 text-white px-6 py-3 rounded-xl hover:bg-gray-600 transition hidden"
        >
            Cancelar
        </button>

        </div>

        <p
        id="mensaje"
        class="mt-4 font-semibold"
        ></p>

    <div class="mt-8">

      <button
        id="guardarBtn"
        class="bg-blue-600 text-white px-6 py-3 rounded-xl hover:bg-blue-700 transition"
      >
        Guardar cambios
      </button>

      <p
        id="mensaje"
        class="mt-4 font-semibold"
      ></p>

    </div>

  </div>

  <script>
    const user = JSON.parse(localStorage.getItem("user"));

    if (!user) {
      window.location.replace("/login");
    }

    if (user.rol_id !== 2) {
      window.location.replace("/dashboard");
    }

    const token = localStorage.getItem("token");

    async function cargarPerfil() {
      try {

        const response = await fetch(
          "http://localhost:3000/api/auth/profile",
          {
            headers: {
              Authorization: `Bearer ${token}`
            }
          }
        );

        const data = await response.json();

        document.getElementById("email").value =
          data.email;

        document.getElementById("estado").textContent =
          data.estado;

        document.getElementById("rol").textContent =
          data.rol_id === 2
            ? "Administrador"
            : "Usuario";

        document.getElementById("fecha").textContent =
          new Date(
            data.fecha_registro
          ).toLocaleDateString();

      } catch (error) {
        console.error(error);
      }
    }

    async function actualizarPerfil() {

      const email =
        document.getElementById("email").value;

      try {

        const response = await fetch(
          "http://localhost:3000/api/auth/profile",
          {
            method: "PUT",
            headers: {
              "Content-Type": "application/json",
              Authorization: `Bearer ${token}`
            },
            body: JSON.stringify({
              email
            })
          }
        );

        const data =
          await response.json();

        const mensaje =
          document.getElementById("mensaje");

        if (!response.ok) {

          mensaje.className =
            "mt-4 text-red-600 font-semibold";

          mensaje.textContent =
            data.error;

          return;
        }

        mensaje.className =
            "mt-4 text-green-600 font-semibold";

        mensaje.textContent =
        data.message;

        emailInput.disabled = true;

        emailInput.classList.add(
        "bg-gray-100"
        );

        editarBtn.classList.remove("hidden");

        guardarBtn.classList.add("hidden");

        cancelarBtn.classList.add("hidden");

        localStorage.setItem(
        "user",
        JSON.stringify({
            ...user,
            email
        })
        );

      } catch (error) {
        console.error(error);
      }
    }

    document
      .getElementById("guardarBtn")
      .addEventListener(
        "click",
        actualizarPerfil
      );

    const emailInput =
  document.getElementById("email");

    const editarBtn =
    document.getElementById("editarBtn");

    const guardarBtn =
    document.getElementById("guardarBtn");

    const cancelarBtn =
    document.getElementById("cancelarBtn");

    let emailOriginal = "";

    editarBtn.addEventListener("click", () => {

    emailOriginal =
        emailInput.value;

    emailInput.disabled = false;

    emailInput.classList.remove(
        "bg-gray-100"
    );

    editarBtn.classList.add("hidden");
    guardarBtn.classList.remove("hidden");
    cancelarBtn.classList.remove("hidden");
    });

    cancelarBtn.addEventListener("click", () => {

    emailInput.value =
        emailOriginal;

    emailInput.disabled = true;

    emailInput.classList.add(
        "bg-gray-100"
    );

    editarBtn.classList.remove("hidden");
    guardarBtn.classList.add("hidden");
    cancelarBtn.classList.add("hidden");
    });


    cargarPerfil();
  </script>

</AdminLayout>