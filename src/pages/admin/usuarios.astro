---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Usuarios">

  <div class="mb-8">
    <h1 class="text-3xl font-bold text-slate-800">
      Gestión de Usuarios
    </h1>

    <p class="text-gray-500 mt-2">
      Lista de usuarios registrados.
    </p>
  </div>

  <div
    id="mensajeEstado"
    class="hidden mb-6 px-5 py-4 rounded-2xl font-semibold"
  ></div>

  <div
    id="usuariosContainer"
    class="grid gap-6"
  >
    <div class="bg-white rounded-3xl shadow-md p-6">
      Cargando usuarios...
    </div>
  </div>

  <script>
    const mensajeEstado =
      document.getElementById("mensajeEstado");

    function mostrarMensaje(texto, tipo = "success") {
      mensajeEstado.className =
        tipo === "success"
          ? "mb-6 px-5 py-4 rounded-2xl font-semibold bg-green-100 text-green-700"
          : "mb-6 px-5 py-4 rounded-2xl font-semibold bg-red-100 text-red-700";

      mensajeEstado.textContent = texto;
      mensajeEstado.classList.remove("hidden");

      setTimeout(() => {
        mensajeEstado.classList.add("hidden");
      }, 3000);
    }

    async function cargarUsuarios() {
      try {
        const token = localStorage.getItem("token");

        const response = await fetch(
          "http://localhost:3000/api/auth/users",
          {
            headers: {
              Authorization: `Bearer ${token}`
            }
          }
        );

        const usuarios = await response.json();

        const container =
          document.getElementById("usuariosContainer");

        container.innerHTML = "";

        if (!response.ok) {
          mostrarMensaje(
            usuarios.error || "No se pudieron cargar los usuarios.",
            "error"
          );
          return;
        }

        if (usuarios.length === 0) {
          container.innerHTML = `
            <div class="bg-white rounded-3xl shadow-md p-6">
              No hay usuarios registrados.
            </div>
          `;
          return;
        }

        usuarios.forEach(usuario => {
          container.innerHTML += `
            <div class="bg-white rounded-3xl shadow-md p-6 border">
              <h2 class="text-xl font-bold mb-2">
                ${usuario.email}
              </h2>

              <p><strong>ID:</strong> ${usuario.id}</p>

              <p>
                <strong>Rol:</strong>
                ${usuario.rol_id === 2 ? "Administrador" : "Usuario"}
              </p>

              <p>
                <strong>Estado:</strong>
                ${usuario.estado}
              </p>

              <div class="mt-4 flex gap-3">
                ${
                  usuario.estado === "activo"
                    ? `
                      <button
                        onclick="desactivarUsuario(${usuario.id})"
                        class="bg-red-600 text-white px-4 py-2 rounded-xl hover:bg-red-700 transition"
                      >
                        Desactivar
                      </button>
                    `
                    : `
                      <button
                        onclick="activarUsuario(${usuario.id})"
                        class="bg-green-600 text-white px-4 py-2 rounded-xl hover:bg-green-700 transition"
                      >
                        Activar
                      </button>
                    `
                }
              </div>
            </div>
          `;
        });

      } catch (error) {
        mostrarMensaje(
          "Error de conexión con el servidor.",
          "error"
        );
      }
    }

    async function desactivarUsuario(id) {
      try {
        const token = localStorage.getItem("token");

        const response = await fetch(
          `http://localhost:3000/api/auth/users/${id}/desactivar`,
          {
            method: "PUT",
            headers: {
              Authorization: `Bearer ${token}`
            }
          }
        );

        const data = await response.json();

        if (response.ok) {
          mostrarMensaje(
            data.message || "Usuario desactivado correctamente.",
            "success"
          );
          cargarUsuarios();
        } else {
          mostrarMensaje(
            data.error || "No se pudo desactivar el usuario.",
            "error"
          );
        }

      } catch (error) {
        mostrarMensaje(
          "Error de conexión con el servidor.",
          "error"
        );
      }
    }

    async function activarUsuario(id) {
      try {
        const token = localStorage.getItem("token");

        const response = await fetch(
          `http://localhost:3000/api/auth/users/${id}/activar`,
          {
            method: "PUT",
            headers: {
              Authorization: `Bearer ${token}`
            }
          }
        );

        const data = await response.json();

        if (response.ok) {
          mostrarMensaje(
            data.message || "Usuario activado correctamente.",
            "success"
          );
          cargarUsuarios();
        } else {
          mostrarMensaje(
            data.error || "No se pudo activar el usuario.",
            "error"
          );
        }

      } catch (error) {
        mostrarMensaje(
          "Error de conexión con el servidor.",
          "error"
        );
      }
    }

    window.activarUsuario = activarUsuario;
    window.desactivarUsuario = desactivarUsuario;

    cargarUsuarios();
  </script>

</AdminLayout>