---
import UserLayout from "../layouts/UserLayout.astro";
---

<UserLayout title="Certificados">

  <div class="mb-8">

    <h1 class="text-4xl font-bold text-slate-800">
      Catálogo de Certificados
    </h1>

    <p class="text-gray-500 mt-2">
      Selecciona el certificado que deseas solicitar.
    </p>

  </div>

  <div
    id="certificadosContainer"
    class="grid md:grid-cols-3 gap-6"
  >

    <div class="text-gray-500">
      Cargando certificados...
    </div>

  </div>

  <script>

    async function cargarCertificados() {

      try {

        const response = await fetch(
          "http://localhost:3000/api/certificados/modelos"
        );

        const certificados =
          await response.json();

        const container =
          document.getElementById(
            "certificadosContainer"
          );

        container.innerHTML = "";

        certificados.forEach(certificado => {

          container.innerHTML += `
            <div
              class="bg-white rounded-3xl shadow-md p-6 hover:shadow-xl transition"
            >

              <h2 class="text-2xl font-bold mb-4">
                ${certificado.nombre}
              </h2>

              <p class="text-gray-600 mb-6">
                ${certificado.descripcion}
              </p>

              <div class="flex gap-3">

                  <a
                    href="/certificados/${certificado.id}"
                    class="bg-blue-600 text-white px-5 py-3 rounded-xl hover:bg-blue-700 transition inline-block"
                  >
                    Ver detalle
                  </a>

                  <a
                    href="/certificados/preview/${certificado.id}"
                    class="bg-green-600 text-white px-5 py-3 rounded-xl hover:bg-green-700 transition inline-block"
                  >
                    Vista previa
                  </a>

              </div>

            </div>
          `;

        });

      } catch (error) {

        console.error(error);

      }

    }

    cargarCertificados();

  </script>

</UserLayout>