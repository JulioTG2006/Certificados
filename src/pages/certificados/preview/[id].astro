---
import UserLayout from "../../../layouts/UserLayout.astro";

export const prerender = false;
---

<UserLayout title="Vista Previa Certificado">

  <div class="mb-8">

    <h1 class="text-4xl font-bold text-slate-800">
      Vista Previa del Certificado
    </h1>

    <p class="text-gray-500 mt-2">
      Ejemplo visual del documento.
    </p>

  </div>

  <div id="previewContainer">

    <div class="text-gray-500">
      Cargando...
    </div>

  </div>

  <script>

    async function cargarPreview() {

      try {

        const id =
          window.location.pathname
            .split("/")
            .pop();

        const response = await fetch(
          `http://localhost:3000/api/certificados/modelos/${id}`
        );

        const certificado =
          await response.json();

        const container =
          document.getElementById(
            "previewContainer"
          );

        container.innerHTML = `
          <div
            class="bg-white border-4 border-slate-300 rounded-3xl shadow-lg p-12 text-center"
          >

            <h1
              class="text-4xl font-bold mb-8"
            >
              ${certificado.nombre}
            </h1>

            <p
              class="text-lg text-gray-600 mb-10"
            >
              ${certificado.descripcion}
            </p>

            <div
              class="border-t pt-10 mt-10"
            >

              <p class="text-xl">
                CERTIFICADO DE EJEMPLO
              </p>

              <p class="mt-6">
                Se certifica que
              </p>

              <p class="text-3xl font-bold mt-4 text-slate-800">
                NOMBRE DEL ESTUDIANTE
                </p>
                <div class="mt-8 text-gray-600">
                Fecha de emisión: 01/06/2026
                </div>

              <p class="mt-6">
                cumple con los requisitos
                establecidos.
              </p>

              <div class="mt-16">
                _____________________
              </div>

              <p>
                Firma Institucional
              </p>

            </div>

          </div>
        `;

      } catch (error) {

        console.error(error);

      }

    }

    cargarPreview();

  </script>

</UserLayout>