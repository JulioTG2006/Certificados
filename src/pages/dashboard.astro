---
import UserLayout from "../layouts/UserLayout.astro";
import Card from "../components/ui/Card.astro";
---

<UserLayout title="Dashboard">

  <div class="mb-10">
    <h1 class="text-4xl font-bold text-slate-800">
      Bienvenido
    </h1>

    <p class="text-gray-500 mt-2">
      Gestiona tus certificados y solicitudes desde aquí.
    </p>
  </div>

  <div class="grid md:grid-cols-3 gap-6 mb-10">
    <Card title="Solicitudes Totales" value="0" />
    <Card title="Pendientes" value="0" />
    <Card title="Aprobadas" value="0" />
  </div>

  <div class="bg-white rounded-3xl shadow-md p-8">
    <h2 class="text-2xl font-bold mb-6">
      Solicitudes recientes
    </h2>

    <div id="solicitudesContainer" class="space-y-4">
      <p class="text-gray-500">Cargando solicitudes...</p>
    </div>
  </div>

  <script>
    const token = localStorage.getItem("token");

    const cards = document.querySelectorAll(".grid .bg-white");
    const solicitudesContainer = document.getElementById("solicitudesContainer");

    async function cargarDashboard() {
      try {
        const response = await fetch("http://localhost:3000/api/solicitudes/mis-solicitudes", {
          headers: {
            Authorization: `Bearer ${token}`
          }
        });

        const solicitudes = await response.json();

        if (!response.ok) {
          solicitudesContainer.innerHTML = `
            <p class="text-red-500">Error al cargar las solicitudes.</p>
          `;
          return;
        }

        const total = solicitudes.length;

        const pendientes = solicitudes.filter(
          s => s.estado === "Pendiente"
        ).length;

        const aprobadas = solicitudes.filter(
          s => s.estado === "Aprobado"
        ).length;

        cards[0].querySelector("p").textContent = total;
        cards[1].querySelector("p").textContent = pendientes;
        cards[2].querySelector("p").textContent = aprobadas;

        if (solicitudes.length === 0) {
          solicitudesContainer.innerHTML = `
            <p class="text-gray-500">No tienes solicitudes registradas.</p>
          `;
          return;
        }

        solicitudesContainer.innerHTML = solicitudes
          .slice(0, 5)
          .map((solicitud, index) => {
            let color = "bg-blue-100 text-blue-700";

            if (solicitud.estado === "Pendiente") {
              color = "bg-yellow-100 text-yellow-700";
            }

            if (solicitud.estado === "Aprobado") {
              color = "bg-green-100 text-green-700";
            }

            if (solicitud.estado === "Rechazado") {
              color = "bg-red-100 text-red-700";
            }

            return `
              <div class="flex justify-between items-center ${
                index !== solicitudes.slice(0, 5).length - 1 ? "border-b pb-4" : ""
              }">
                <span>${solicitud.tipo_certificado || solicitud.tipo || "Solicitud"}</span>
                <span class="${color} px-4 py-1 rounded-full text-sm">
                  ${solicitud.estado}
                </span>
              </div>
            `;
          })
          .join("");

      } catch (error) {
        solicitudesContainer.innerHTML = `
          <p class="text-red-500">No se pudo conectar con el servidor.</p>
        `;
      }
    }

    cargarDashboard();
  </script>

</UserLayout>